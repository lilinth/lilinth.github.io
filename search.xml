    <content><![CDATA[<figure class="highlight bash"><table><tr><td class="code"><pre><span class="line"><span class="built_in">set</span> PATH=<span class="string">&quot;%ConEmuBaseDirShort%\wsl&quot;</span>;%PATH% &amp; wsl -d ubuntu</span><br></pre></td></tr></table></figure>]]></content>
